{
  "name": "@gridnexa/angular",
  "version": "0.1.9",
  "description": "Enterprise Angular data grid for modern UI apps with Excel-like filtering, editing, formulas, grouping, pivoting, export, and native Angular UX.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./index.css": "./dist/index.css",
    "./dist/index.css": "./dist/index.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external @angular/core",
    "dev": "tsup src/index.ts --watch --external @angular/core",
    "clean": "rimraf dist"
  },
  "keywords": [
    "gridnexa",
    "angular-grid",
    "angular-data-grid",
    "angular",
    "data-grid",
    "datagrid",
    "enterprise-grid",
    "excel-grid",
    "spreadsheet",
    "table",
    "pivot-table",
    "tree-grid",
    "filtering",
    "sorting",
    "editable-grid",
    "csv-export",
    "excel-export",
    "typescript"
  ],
  "homepage": "https://www.gridnexa.in/",
  "bugs": {
    "url": "https://www.gridnexa.in/help"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mhalungekar9/SmartGrid.git",
    "directory": "packages/angular"
  },
  "author": "Sachin M",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@angular/core": ">=16"
  },
  "dependencies": {
    "@gridnexa/core": "workspace:^"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
