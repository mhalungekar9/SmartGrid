{
    "name":  "@gridnexa/vue",
    "version":  "0.1.18",
    "description":  "Vue data grid and Vue table for modern apps with Excel-like editing, filtering, formulas, grouping, pivoting, export, and TypeScript APIs.",
    "type":  "module",
    "main":  "./dist/index.js",
    "module":  "./dist/index.js",
    "types":  "./dist/index.d.ts",
    "exports":  {
                    ".":  {
                              "types":  "./dist/index.d.ts",
                              "import":  "./dist/index.js",
                              "require":  "./dist/index.cjs"
                          },
                    "./index.css":  "./dist/index.css",
                    "./dist/index.css":  "./dist/index.css"
                },
    "files":  [
                  "dist",
                  "README.md"
              ],
    "sideEffects":  [
                        "*.css"
                    ],
    "scripts":  {
                    "build":  "tsup src/index.ts --format esm,cjs --dts --external vue",
                    "dev":  "tsup src/index.ts --watch --external vue",
                    "clean":  "rimraf dist"
                },
    "keywords":  [
                     "gridnexa",
                     "vue-grid",
                     "vue-data-grid",
                     "vue-table",
                     "vue-datagrid",
                     "vue-data-table",
                     "vue",
                     "data-grid",
                     "data-table",
                     "datagrid",
                     "grid",
                     "table",
                     "ag-grid-alternative",
                     "enterprise-grid",
                     "excel-grid",
                     "spreadsheet",
                     "pivot-table",
                     "tree-grid",
                     "filtering",
                     "sorting",
                     "editable-grid",
                     "csv-export",
                     "excel-export",
                     "typescript"
                 ],
    "homepage":  "https://www.gridnexa.in/",
    "bugs":  {
                 "url":  "https://www.gridnexa.in/help"
             },
    "repository":  {
                       "type":  "git",
                       "url":  "git+https://github.com/mhalungekar9/gridnexa.git",
                       "directory":  "packages/vue"
                   },
    "author":  "Sachin M",
    "license":  "MIT",
    "publishConfig":  {
                          "access":  "public"
                      },
    "peerDependencies":  {
                             "vue":  "\u003e=3"
                         },
    "dependencies":  {
                         "@gridnexa/core":  "workspace:^"
                     },
    "devDependencies":  {
                            "rimraf":  "^6.1.3",
                            "tsup":  "^8.5.1",
                            "typescript":  "^5.9.3"
                        }
}
