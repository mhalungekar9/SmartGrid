{
  "name": "@smartgrid/react",
  "version": "0.0.1",
  "description": "React wrapper for SmartGrid",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --watch",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-popover": "^1.1.18",
    "@smartgrid/core": "workspace:*",
    "lucide-react": "^1.23.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.0"
  }
}
