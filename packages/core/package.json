{
  "name": "@gridnexa/core",
  "version": "0.1.5",
  "description": "Shared TypeScript models, grid options, filtering contracts, and framework-neutral utilities for GridNexa enterprise data grids.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --watch",
    "clean": "rimraf dist"
  },
  "keywords": [
    "gridnexa",
    "grid",
    "data-grid",
    "datagrid",
    "enterprise-grid",
    "excel-grid",
    "spreadsheet",
    "excel",
    "table",
    "typescript",
    "filtering",
    "pivot-table",
    "tree-grid"
  ],
  "homepage": "https://www.gridnexa.in/",
  "bugs": {
    "url": "https://www.gridnexa.in/help"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mhalungekar9/SmartGrid.git",
    "directory": "packages/core"
  },
  "author": "Sachin M",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
